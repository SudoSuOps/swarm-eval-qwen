{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SwarmJudge Training Pair",
  "description": "Schema for judge training pairs. Every pair in train/eval must validate.",
  "type": "object",
  "required": ["messages", "metadata"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "contains": {
        "properties": { "role": { "const": "assistant" } },
        "required": ["role"]
      }
    },
    "metadata": {
      "type": "object",
      "required": ["fingerprint", "task_type", "source"],
      "properties": {
        "fingerprint": {
          "type": "string",
          "minLength": 8,
          "description": "Dedup key — unique per pair"
        },
        "task_type": {
          "type": "string",
          "description": "CRE specialty or task category"
        },
        "source": {
          "type": "string",
          "description": "Cook run ID or data source identifier"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "specialty": {
          "type": "string"
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        }
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "assistant_content": {
      "description": "The assistant message content must be valid JSON with verdict and scores",
      "type": "object",
      "required": ["verdict", "scores", "reasoning"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASS", "FAIL"]
        },
        "scores": {
          "type": "object",
          "required": ["accuracy", "completeness", "structure", "relevance", "sft_quality"],
          "properties": {
            "accuracy": { "type": "number", "minimum": 1, "maximum": 5 },
            "completeness": { "type": "number", "minimum": 1, "maximum": 5 },
            "structure": { "type": "number", "minimum": 1, "maximum": 5 },
            "relevance": { "type": "number", "minimum": 1, "maximum": 5 },
            "sft_quality": { "type": "number", "minimum": 1, "maximum": 5 }
          }
        },
        "reasoning": {}
      }
    }
  }
}
